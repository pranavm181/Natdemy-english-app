# Python
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
venv/
env/
ENV/
bin/
include/
lib/
lib64/
share/
*.venv
pip-log.txt
pip-delete-this-directory.txt

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.whl

# Django
# Media and static files (adjust as needed, generally ignore collected static files)
# See Stack Overflow for more info: https://stackoverflow.com/questions/47342905/what-type-files-should-be-put-into-gitignore-file-in-django-project
static_cdn/
media/*
*.log
local_settings.py

# NPM / Node
# Dependency directory
node_modules/

# Logs and temporary files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Optional: Build artifacts (if not generated by Django/Python)
# dist/
# build/

# Editors and OS files
.idea/  # IDE-specific files (e.g., PyCharm)
.vscode/ # VS Code specific files
.DS_Store
Thumbs.db
